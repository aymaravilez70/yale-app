              }
            }
            if (window.videojs) {
              const players = window.videojs.players;
              for (const id in players) {
                const p = players[id];
                if (p && typeof p.play === 'function' && p.paused()) {
                   log("⚡ [VideoJS API Shield] Forzando reproducción mediante API de VideoJS...");
                   p.play();
                }
              }
